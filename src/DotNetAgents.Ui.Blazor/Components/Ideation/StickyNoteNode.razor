@using DotNetAgents.Ui.Core.Ideation

<article class="dna-ideation-node dna-ideation-node--sticky" style="@PositionStyle">
    <header>
        <span>Sticky note</span>
        <button type="button" @onclick="DeleteAsync" aria-label="Delete sticky note">×</button>
    </header>
    <strong>@Node.Title</strong>
    <p>@Node.PayloadJson</p>
</article>

@code {
    [Parameter, EditorRequired] public IdeationNode Node { get; set; } = default!;
    [Parameter] public EventCallback<IdeationNode> OnUpdateNode { get; set; }
    [Parameter] public EventCallback<string> OnDeleteNode { get; set; }

    private string PositionStyle => $"left:{Node.Position.X:0}px; top:{Node.Position.Y:0}px; z-index:{Node.Position.ZIndex};";
    private Task DeleteAsync() => OnDeleteNode.InvokeAsync(Node.NodeId);
}
