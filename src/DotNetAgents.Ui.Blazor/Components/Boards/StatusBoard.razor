@using DotNetAgents.Ui.Core

<div class="dna-status-board" role="region" aria-label="Workflow columns">
    @foreach (var column in Columns)
    {
        <section class="dna-status-board__column @IntentClass(column.Intent)"
                 role="region"
                 aria-label="@column.Label">
            <header class="dna-status-board__column-header">
                <div>
                    <h3>@column.Label</h3>
                    @if (!string.IsNullOrWhiteSpace(column.Summary))
                    {
                        <p>@column.Summary</p>
                    }
                </div>
                <span class="dna-status-board__count">@column.Cards.Count</span>
            </header>

            <div class="dna-status-board__cards">
                @if (column.Cards.Count == 0)
                {
                    <div class="dna-status-board__empty">
                        @(!string.IsNullOrWhiteSpace(column.EmptyState) ? column.EmptyState : "No items in this stage.")
                    </div>
                }
                else
                {
                    @foreach (var card in column.Cards)
                    {
                        <article class="dna-status-board__card @IntentClass(card.Intent)">
                            <div class="dna-status-board__card-top">
                                @if (!string.IsNullOrWhiteSpace(card.Badge))
                                {
                                    <span class="dna-status-board__badge">@card.Badge</span>
                                }
                                <h4>
                                    @if (!string.IsNullOrWhiteSpace(card.Href))
                                    {
                                        <a class="dna-status-board__card-title-link" href="@card.Href">@card.Title</a>
                                    }
                                    else
                                    {
                                        @card.Title
                                    }
                                </h4>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(card.PreviewImageUrl))
                            {
                                <figure class="dna-status-board__preview">
                                    <img src="@card.PreviewImageUrl"
                                         alt=""
                                         loading="lazy"
                                         referrerpolicy="no-referrer"
                                         width="400"
                                         height="225" />
                                </figure>
                            }

                            @if (!string.IsNullOrWhiteSpace(card.Meta))
                            {
                                <div class="dna-status-board__meta">@card.Meta</div>
                            }

                            @if (!string.IsNullOrWhiteSpace(card.SecondaryText))
                            {
                                <p class="dna-status-board__secondary">@card.SecondaryText</p>
                            }

                            @if (card.Highlights is { Count: > 0 })
                            {
                                <ul class="dna-status-board__highlights">
                                    @foreach (var item in card.Highlights)
                                    {
                                        <li>@item</li>
                                    }
                                </ul>
                            }
                        </article>
                    }
                }
            </div>
        </section>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<BoardColumnModel> Columns { get; set; } = [];

    private static string IntentClass(UiIntent intent) => intent switch
    {
        UiIntent.Primary => "dna-status-board--primary",
        UiIntent.Info => "dna-status-board--info",
        UiIntent.Success => "dna-status-board--success",
        UiIntent.Warning => "dna-status-board--warning",
        UiIntent.Danger => "dna-status-board--danger",
        _ => "dna-status-board--neutral"
    };
}

<style>
    .dna-status-board {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
        align-items: start;
        width: 100%;
        min-width: 0;
        box-sizing: border-box;
    }

    .dna-status-board__column {
        background: linear-gradient(180deg, rgba(7, 16, 31, 0.96), var(--dna-surface-card, rgba(14, 27, 51, 0.9)));
        border: 1px solid var(--dna-border-strong, rgba(100, 171, 225, 0.5));
        border-top: 4px solid var(--dna-column-accent, #94a3b8);
        border-radius: 14px;
        box-shadow: var(--dna-shadow-md, 0 14px 34px rgba(0, 8, 24, 0.52));
        min-height: 15rem;
        min-width: 0;
        max-width: 100%;
        display: flex;
        flex-direction: column;
    }

    .dna-status-board__column-header {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 1rem 1rem 0.75rem;
        border-bottom: 1px solid var(--dna-border-muted, rgba(83, 137, 178, 0.3));
    }

    .dna-status-board__column-header h3 {
        margin: 0;
        font-size: 1rem;
        color: var(--dna-text-primary, #0f172a);
    }

    .dna-status-board__column-header p {
        margin: 0.35rem 0 0;
        color: var(--dna-text-muted, #64748b);
        font-size: 0.88rem;
    }

    .dna-status-board__count {
        align-self: start;
        min-width: 1.9rem;
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        background: rgba(148, 163, 184, 0.18);
        color: var(--dna-text-secondary, #c6dcee);
        font-size: 0.84rem;
        font-weight: 700;
        text-align: center;
    }

    .dna-status-board__cards {
        display: grid;
        gap: 0.75rem;
        padding: 0.9rem;
        min-width: 0;
        flex: 1 1 auto;
        align-content: start;
    }

    .dna-status-board__card {
        border-radius: 12px;
        border: 1px solid rgba(100, 171, 225, 0.24);
        background: linear-gradient(180deg, rgba(14, 27, 51, 0.98), rgba(20, 40, 72, 0.92));
        padding: 0.85rem 0.9rem;
        min-width: 0;
        max-width: 100%;
        overflow: hidden;
        box-sizing: border-box;
        color: var(--dna-text-primary, #f6fbff);
        box-shadow: 0 10px 20px rgba(0, 8, 24, 0.22);
        transition: border-color 0.16s ease, transform 0.16s ease, box-shadow 0.16s ease;
    }

    .dna-status-board__card:hover {
        border-color: rgba(93, 216, 255, 0.46);
        box-shadow: 0 16px 30px rgba(0, 8, 24, 0.3);
        transform: translateY(-1px);
    }

    .dna-status-board__card-top {
        display: grid;
        gap: 0.45rem;
        align-items: start;
    }

    .dna-status-board__card-top h4 {
        margin: 0;
        font-size: 0.96rem;
        line-height: 1.35;
        color: var(--dna-text-primary, #0f172a);
        overflow-wrap: anywhere;
        word-break: break-word;
    }

    a.dna-status-board__card-title-link {
        color: inherit;
        text-decoration: none;
    }

    a.dna-status-board__card-title-link:hover {
        color: var(--dna-accent-primary, #5dd8ff);
        text-decoration: underline;
    }

    .dna-status-board__badge {
        white-space: nowrap;
        border-radius: 999px;
        padding: 0.18rem 0.55rem;
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--dna-text-primary, #f6fbff);
        background: rgba(93, 216, 255, 0.16);
        justify-self: start;
    }

    .dna-status-board__meta {
        margin-top: 0.5rem;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--dna-text-secondary, #c6dcee);
        overflow-wrap: anywhere;
    }

    .dna-status-board__preview {
        margin: 0.5rem 0 0;
        padding: 0;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid rgba(100, 171, 225, 0.18);
        background: rgba(7, 16, 31, 0.92);
        max-height: 9rem;
    }

    .dna-status-board__preview img {
        display: block;
        width: 100%;
        height: auto;
        max-height: 9rem;
        object-fit: contain;
    }

    .dna-status-board__secondary {
        margin: 0.45rem 0 0;
        color: var(--dna-text-secondary, #c6dcee);
        font-size: 0.85rem;
        line-height: 1.4;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
        word-break: break-word;
        max-height: 14rem;
        overflow-y: auto;
    }

    .dna-status-board__highlights {
        margin: 0.65rem 0 0;
        padding-left: 1rem;
        color: var(--dna-text-secondary, #c6dcee);
        font-size: 0.82rem;
        line-height: 1.4;
        overflow-wrap: anywhere;
    }

    .dna-status-board__empty {
        border: 1px dashed rgba(100, 171, 225, 0.22);
        border-radius: 10px;
        padding: 0.9rem;
        color: var(--dna-text-muted, #91b4cf);
        font-size: 0.86rem;
        background: rgba(10, 19, 37, 0.78);
    }

    .dna-status-board--neutral { --dna-column-accent: #94a3b8; }
    .dna-status-board--primary { --dna-column-accent: #6366f1; }
    .dna-status-board--info { --dna-column-accent: #0ea5e9; }
    .dna-status-board--success { --dna-column-accent: #16a34a; }
    .dna-status-board--warning { --dna-column-accent: #ea580c; }
    .dna-status-board--danger { --dna-column-accent: #dc2626; }
</style>
